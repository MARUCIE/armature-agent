{
  "name": "armature-agent",
  "version": "0.8.16",
  "description": "Armature CLI — provider-neutral agent runtime with Claude Code depth",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "armature": "./dist/bin/armature.js",
    "armature-agent": "./dist/bin/armature.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "node --experimental-vm-modules node_modules/.bin/vitest run",
    "lint": "tsc --noEmit",
    "test:static": "python3 agent-eval/scripts/run-test-matrix.py --layers static",
    "test:unit": "python3 agent-eval/scripts/run-test-matrix.py --layers unit",
    "test:contract": "python3 agent-eval/scripts/run-test-matrix.py --layers contract",
    "test:integration": "python3 agent-eval/scripts/run-test-matrix.py --layers integration",
    "test:e2e": "python3 agent-eval/scripts/run-test-matrix.py --layers e2e",
    "test:security": "python3 agent-eval/scripts/run-test-matrix.py --layers security",
    "test:resilience": "python3 agent-eval/scripts/run-test-matrix.py --layers resilience",
    "test:performance": "python3 agent-eval/scripts/run-test-matrix.py --layers performance",
    "test:ai-eval-fast": "python3 agent-eval/scripts/run-test-matrix.py --layers ai-eval",
    "test:matrix": "python3 agent-eval/scripts/run-test-matrix.py",
    "test:matrix:sync": "python3 agent-eval/scripts/sync-test-matrix.py --check",
    "dev": "tsc --watch",
    "bench": "node dist/bin/armature.js bench",
    "eval:fast": "python3 agent-eval/scripts/run-gate.py --manifest fast",
    "eval:nightly": "python3 agent-eval/scripts/run-gate.py --manifest nightly",
    "eval:release": "python3 agent-eval/scripts/run-gate.py --manifest release",
    "prepublishOnly": "npm run build && npm test && npm run bench",
    "test:tool-calls": "python3 agent-eval/scripts/run-test-matrix.py --layers tool-calls"
  },
  "dependencies": {
    "acorn": "^8.16.0",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "https-proxy-agent": "^7.0.0",
    "ink": "^5.2.1",
    "ink-spinner": "^5.0.0",
    "marked": "^15.0.12",
    "marked-terminal": "^7.3.0",
    "openai": "^6.33.0",
    "react": "^18.3.1",
    "undici": "^7.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.28",
    "ink-testing-library": "^4.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "cli",
    "agent",
    "coding-agent",
    "armature",
    "multi-model",
    "openai",
    "claude",
    "gemini",
    "gpt",
    "benchmark"
  ],
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/MARUCIE/armature-agent.git"
  },
  "homepage": "https://github.com/MARUCIE/armature-agent",
  "license": "MIT",
  "author": {
    "name": "Maurice",
    "email": "maurice_wen@proton.me"
  }
}
